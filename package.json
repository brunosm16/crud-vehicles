{
  "name": "crud-vehicles-monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "start:api": "pnpm --filter @crud-vehicles/api start:dev",
    "start:web": "pnpm --filter @crud-vehicles/web start",
    "start:audit": "pnpm --filter @crud-vehicles/audit start:dev",
    "start:all": "pnpm start:api & pnpm start:web",
    "mdfix": "prettier *.md --write",
    "precommit": "lint-staged && pnpm test && pnpm build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "husky:install": "husky"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^17.5.3",
    "@angular-eslint/eslint-plugin-template": "^17.5.3",
    "@angular-eslint/template-parser": "^17.5.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.2",
    "@typescript-eslint/rule-tester": "^8.34.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "prettier": "^3.8.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "typescript-eslint": "^8.34.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
